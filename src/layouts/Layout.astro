---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/vendor.css';
const { showHeader = true, showFooter = true } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title id="title">My Resume</title>
    <link rel="stylesheet" href="/style.css">
    <Analytics />
</head>

<body>
    {showHeader &&
    <nav class="navbar navbar-expand-lg navbar-light bg-light px-3 rounded shadow-sm">
        <a id="name-logo" class="navbar-brand fw-bold" href="#">Qianrui Liu</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
            aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" href="#intro" id="nav-intro">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="#edu" id="nav-edu">Education</a></li>
                <li class="nav-item"><a class="nav-link" href="#project-list" id="nav-projects">Projects</a></li>
                <li class="nav-item"><a class="nav-link" href="#skills" id="nav-skills">Skills & Awards</a></li>
                <li class="nav-item"><a class="nav-link" href="#footer" id="nav-contact">Contact</a></li>
            </ul>
            <div class="d-flex align-items-center gap-2">
                <!-- 语言切换 -->
                <div class="btn-group" role="group" aria-label="Language Switch">
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="setLang('en')">EN</button>
                    <button type="button" class="btn btn-outline-success btn-sm" onclick="setLang('zh')">CN</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="setLang('jp')">JP</button>
                </div>
                <!-- 夜间模式切换 -->
                <button id="toggle-dark" class="btn btn-outline-secondary" title="Dark Mode">☾/☼</button>
            </div>
        </div>
    </nav>
    }
    <main>
        <slot />
    </main>
    {showFooter &&
    <section id="footer" class="gradient-background">
        <div class="container">
            <footer class="d-flex flex-wrap justify-content-between align-items-center py-3 border-top">
                <div class="col-md-4 d-flex align-items-center">
                    <a href="/"
                        class="mb-3 me-2 mb-md-0 text-body-secondary text-decoration-none lh-1" aria-label="Bootstrap">
                        <svg class="bi" width="30" height="24" aria-hidden="true">
                            <use xlink:href="#bootstrap"></use>
                        </svg>
                        <span id="footer-text" class="text-body-secondary">
                            © 2025 Qianrui Liu
                        </span>
                    </a>
                </div>
            </footer>
        </div>
    </section>
    }
    {showHeader && <script src="../scripts/bootstrap.js"></script>}
    {showHeader && <script is:inline src="/index.js" charset="UTF-8"></script>}
    <SpeedInsights />
</body>

</html>
